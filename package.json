{
  "name": "sano.music",
  "version": "1.5.3",
  "engines": {
    "node": ">=20"
  },
  "description": "sano.music — a clean, minimal Discord music bot",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch ./src/Bot.ts",
    "start": "node index.js",
    "start:compiled": "node ./dist/Bot.js",
    "build": "tsup ./src/Bot.ts --minify",
    "build:full": "npm run lint && npm run build",
    "postinstall": "node -e \"try{require('fs').existsSync('./dist/Bot.js')||require('child_process').execSync('npm run build',{stdio:'inherit'})}catch(e){console.log('[postinstall] build skipped:',e.message)}\"",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "test": "vitest run",
    "test:functional": "vitest run src/tests/functional",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "knip": "knip",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f sano",
    "docker:clean": "docker compose down -v"
  },
  "author": "sano.senxpai",
  "license": "GPL-3.0",
  "dependencies": {
    "@discordjs/opus": "0.10.0",
    "@discordjs/voice": "0.19.2",
    "better-sqlite3": "^12.9.0",
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "i18n-js": "4.5.3",
    "libsodium-wrappers": "0.8.3",
    "youtube-dl-exec": "^3.1.5",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "^2.30.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "knip": "6.4.1",
    "lefthook": "2.1.6",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
